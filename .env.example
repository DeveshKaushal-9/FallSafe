# Copy this file to `.env` and fill in your values.
# .env is gitignored and never committed.

# Path to the meshroom_batch binary (auto-detected if not set)
# MESHROOM_BINARY=/home/yourname/Meshroom-2023.3.0/meshroom_batch

# FFmpeg FPS for video frame extraction (default: 2)
# FFMPEG_FPS=2

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex())")
SECRET_KEY=change-me-to-a-random-secret

# Folder paths (relative to project root, defaults below)
# UPLOAD_FOLDER=uploads
# OUTPUT_FOLDER=outputs
